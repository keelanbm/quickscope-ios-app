{
  "expo": {
    "name": "Quickscope",
    "slug": "quickscope-ios-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quickscope",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "0.1.0",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.quickscope.iosapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.quickscope.iosapp"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0810"
        }
      ],
      "expo-secure-store",
      "expo-web-browser",
      "expo-dev-client",
      "expo-font",
      "expo-image",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.quickscope.iosapp",
          "widgets": [
            {
              "name": "PortfolioWidget",
              "displayName": "Portfolio",
              "description": "Your portfolio value and top holdings",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "WatchlistWidget",
              "displayName": "Watchlist",
              "description": "Your top watched tokens",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "WalletActivityWidget",
              "displayName": "Wallet Activity",
              "description": "Hot tokens from your tracked wallets",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            },
            {
              "name": "ChatPulseWidget",
              "displayName": "Chat Pulse",
              "description": "Trending tokens in your chats",
              "supportedFamilies": ["systemSmall", "systemMedium"]
            }
          ]
        }
      ]
    ],
    "extra": {
      "projectName": "quickscope-ios-app",
      "privyAppId": "cmip3swbs0061l50d06fdtjhk",
      "privyClientId": "client-WY6TP7bXRg8BP5johqPKj9oN4ybb8h5yXsRY4JM9QXdbM",
      "eas": {
        "projectId": "432c9fe0-204a-4b76-9e33-fde84aba4946"
      }
    },
    "owner": "keelanbm",
    "updates": {
      "url": "https://u.expo.dev/432c9fe0-204a-4b76-9e33-fde84aba4946"
    }
  }
}
